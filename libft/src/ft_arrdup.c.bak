#include "../includes/libft.h"

int *ft_arrdup(const int *src, int size)
{
    int    *dst;
    int    i;

    if (!src || size <= 0)
        return (NULL);
    dst = malloc(sizeof(int) * size);
    if (!dst)
        return (NULL);
    i = 0;
    while (i < size)
    {
        dst[i] = src[i];
        i++;
    }
    return (dst);
}
